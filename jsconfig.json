{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "checkJs": true,
        "allowJs": true,
        "typeRoots": [
            "./node_modules/@types",
            "./typings"
        ],
        "baseUrl": ".",
        "paths": {
            "*": [
                "typings/*"
            ]
        }
    },
    "include": [
        "typings/**/*",
        "scripts/**/*.js",
        "source/_inject/**/*.ejs"
    ],
    "exclude": [
        "node_modules",
        "public"
    ]
}